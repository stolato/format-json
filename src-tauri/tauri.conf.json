{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JSONEdit",
  "version": "1.8.2",
  "identifier": "com.formatjson.app",
  "build": {
    "frontendDist": "../dist/formatjson/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JSONEdit - IDE",
        "width": 1280,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Tilt Tecnologia",
    "shortDescription": "Modern JSON Editor IDE",
    "longDescription": "A professional and high-density IDE-style JSON editor and formatter with real-time socket collaboration support.",
    "targets": [
      "deb",
      "rpm",
      "nsis",
      "msi",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}