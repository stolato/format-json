{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JSONEdit",
  "version": "1.8.20",
  "identifier": "com.formatjson.app",
  "build": {
    "frontendDist": "../dist/formatjson/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "JSONEdit - IDE",
        "width": 1280,
        "height": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["jsonedit"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/stolato/format-json/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk1NzE4OUVCMDI1Q0FEQTEKUldTaHJWd0M2NGx4bFZ1TGVUNHpJUDVPRFFmelRxM0h5YmkyYUYyV1hRci9NeUc3QmVPUVZsOUIK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "Tilt Tecnologia",
    "shortDescription": "Modern JSON Editor IDE",
    "longDescription": "A professional and high-density IDE-style JSON editor and formatter with real-time socket collaboration support.",
    "targets": [
      "deb",
      "rpm",
      "appimage",
      "nsis",
      "msi",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}